<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Collage event Gallery</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.8/dist/css/bootstrap.min.css" rel="stylesheet" integrity="sha384-sRIl4kxILFvY47J16cr9ZwB07vP4J8+LH7qKQnuqkuIAvNWLzeN8tE5YBujZqJLB" crossorigin="anonymous">
</head>
<body class="container-fluid">
    <div class="container mt-5">
        <h2 class="text-center mb-4">Image gallery with alert and modal</h2>
        <div id="alertbox"></div>

        <!--image gallery-->
        <div class="row">
           <div class="col-md-4 mb-3">
            <img src="data:image/jpeg;base64," class="img-fluid" data-bs-toggle="modal"
            data-bs-target="#imgmodal" onclick="showimage(this.src)">
           </div> 

        
           <div class="col-md-4 mb-3">
            <img src="data:image/jpeg;base64," class="img-fluid" data-bs-toggle="modal"
            data-bs-target="#imgmodal" onclick="showimage(this.src)">
           </div> 

           <div class="col-md-4 mb-3">
            <img src="data:image/jpeg;base64," class="img-fluid"  data-bs-toggle="modal"
             data-bs-target="#imgmodal" onclick="showimage(this.src)">
           </div>
        </div>

        <div class="text-center mt-3">
            <button class="btn btn-primary" onclick="showalert('register successfully!')">Register</button>
            <button class="btn btn-success" onclick="showalert('You liked this gallery')">Like</button>
        </div>

        <!--modal-->
        <div class="modal fade" id="imgmodal">
            <div class="modal-dialog modal-dialog-centered">
                <div class="modal-content">
                    <div class="modal-body text-center"></div>
                </div>
            </div>
        </div>
    </div>
    
</body>
</html>
